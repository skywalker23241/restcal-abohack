{
    "name": "xiuli",
    "productName": "休历",
    "version": "1.3.0",
    "description": "休历 - 管理请假、出勤、工资扣除和节假日火车票购票提醒的本地日历工具",
    "license": "MIT",
    "author": "skywalker23241",
    "main": "desktop/main.js",
    "scripts": {
        "start": "electron .",
        "serve": "node server.js",
        "dist": "electron-builder --win"
    },
    "devDependencies": {
        "electron": "^33.2.0",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.skywalker23241.xiuli",
        "productName": "休历",
        "directories": {
            "output": "dist"
        },
        "files": [
            "desktop/**",
            "app.html",
            "app-i18n-v1.4.8.js",
            "calendar-years.js",
            "onboarding.js",
            "styles.css",
            "manifest.webmanifest",
            "sw.js",
            "icons/**",
            "vendor/**",
            "LICENSE"
        ],
        "win": {
            "target": [
                "portable",
                "zip",
                "nsis"
            ],
            "icon": "icons/icon-512.png"
        },
        "portable": {
            "artifactName": "休历-${version}-portable.exe"
        },
        "nsis": {
            "artifactName": "休历-${version}-setup.exe",
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "electronDownload": {
            "mirror": "https://npmmirror.com/mirrors/electron/"
        }
    }
}
